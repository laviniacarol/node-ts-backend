{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./build",

    "module": "commonjs",
    "target": "ES2020",
    "types": ["node", "jest"],

    "sourceMap": true,
      
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,


    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["src"]
}